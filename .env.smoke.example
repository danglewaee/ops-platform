OPS_PLATFORM_API_PORT=8000
OPS_PLATFORM_DB_PATH=/app/artifacts/ops_platform.sqlite3
OPS_PLATFORM_AUTO_INIT_STORAGE=true
OPS_PLATFORM_AUTH_ENABLED=true
OPS_PLATFORM_API_KEYS=smoke-token
OPS_PLATFORM_AUTH_HEADER_NAME=x-api-key
OPS_PLATFORM_ACTOR_HEADER_NAME=x-ops-actor
OPS_PLATFORM_RATE_LIMIT_ENABLED=true
OPS_PLATFORM_RATE_LIMIT_BACKEND=memory
OPS_PLATFORM_RATE_LIMIT_REQUESTS=120
OPS_PLATFORM_RATE_LIMIT_WINDOW_SECONDS=60
OPS_PLATFORM_AUDIT_LOG_ENABLED=true
OPS_PLATFORM_ENABLE_TRACING=false
