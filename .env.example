OPS_PLATFORM_API_HOST=0.0.0.0
OPS_PLATFORM_API_PORT=8000
# Keep this DSN aligned with OPS_PLATFORM_POSTGRES_* below when customizing credentials.
OPS_PLATFORM_DB_PATH=postgresql://ops:ops@timescaledb:5432/ops_platform
OPS_PLATFORM_AUTO_INIT_STORAGE=true
OPS_PLATFORM_AUTH_ENABLED=true
OPS_PLATFORM_API_KEYS=change-me-token
OPS_PLATFORM_AUTH_HEADER_NAME=x-api-key
OPS_PLATFORM_ACTOR_HEADER_NAME=x-ops-actor
OPS_PLATFORM_RATE_LIMIT_ENABLED=true
OPS_PLATFORM_RATE_LIMIT_BACKEND=redis
OPS_PLATFORM_RATE_LIMIT_REQUESTS=120
OPS_PLATFORM_RATE_LIMIT_WINDOW_SECONDS=60
OPS_PLATFORM_REDIS_URL=redis://redis:6379/0
OPS_PLATFORM_REDIS_KEY_PREFIX=ops-platform:rate-limit
OPS_PLATFORM_AUDIT_LOG_ENABLED=true
OPS_PLATFORM_DB_RETRY_ATTEMPTS=5
OPS_PLATFORM_DB_RETRY_BACKOFF_SECONDS=0.5
OPS_PLATFORM_DB_RETRY_MAX_BACKOFF_SECONDS=5.0
OPS_PLATFORM_ENABLE_TRACING=true
OPS_PLATFORM_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
OPS_PLATFORM_OTEL_SERVICE_NAME=ops-decision-platform-api
OPS_PLATFORM_TIMESCALE_METRIC_RETENTION_DAYS=30
OPS_PLATFORM_TIMESCALE_EVENT_RETENTION_DAYS=14
OPS_PLATFORM_TIMESCALE_COMPRESS_AFTER_DAYS=7
OPS_PLATFORM_TIMESCALE_CREATE_METRIC_ROLLUP=true
OPS_PLATFORM_TIMESCALE_AGGREGATE_BUCKET=5 minutes
OPS_PLATFORM_TIMESCALE_AGGREGATE_NAME=metric_samples_5m
OPS_PLATFORM_TIMESCALE_REFRESH_START_OFFSET=30 days
OPS_PLATFORM_TIMESCALE_REFRESH_END_OFFSET=5 minutes
OPS_PLATFORM_TIMESCALE_REFRESH_SCHEDULE_INTERVAL=5 minutes
OPS_PLATFORM_POSTGRES_DB=ops_platform
OPS_PLATFORM_POSTGRES_USER=ops
OPS_PLATFORM_POSTGRES_PASSWORD=ops
